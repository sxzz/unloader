{
  "name": "unloader",
  "type": "module",
  "version": "0.8.3",
  "packageManager": "pnpm@10.33.0",
  "description": "Node.js loader with a Rollup-like interface.",
  "author": "Kevin Deng <sxzz@sxzz.moe>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/sxzz",
  "homepage": "https://github.com/sxzz/unloader#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sxzz/unloader.git"
  },
  "bugs": {
    "url": "https://github.com/sxzz/unloader/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./register": "./dist/register.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "node --test",
    "typecheck": "tsgo --noEmit",
    "format": "prettier --cache --write .",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@jridgewell/remapping": "^2.3.5",
    "obug": "^2.1.1",
    "picomatch": "^4.0.4",
    "unconfig": "^7.5.0"
  },
  "inlinedDependencies": {
    "@antfu/utils": "9.3.0"
  },
  "devDependencies": {
    "@antfu/utils": "^9.3.0",
    "@sxzz/eslint-config": "^7.8.4",
    "@sxzz/prettier-config": "^2.3.1",
    "@types/node": "^24.12.2",
    "@types/picomatch": "^4.0.3",
    "@typescript/native-preview": "7.0.0-dev.20260412.1",
    "bumpp": "^11.0.1",
    "eslint": "^10.2.0",
    "magic-string": "^0.30.21",
    "prettier": "^3.8.2",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "prettier": "@sxzz/prettier-config"
}
